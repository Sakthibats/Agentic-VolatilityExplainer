{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.*.local)",
      "Read(./secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/credentials.json)",
      "Bash(cat .env)",
      "Bash(cat .env.local)",
      "Bash(grep * .env)",
      "Bash(grep * .env.local)"
    ]
  }
}
